---
interface Props {
  title: string;
  href: string;
  category: string;
  date: string;
  isPR?: boolean;
}
const { title, href, category, date, isPR = false } = Astro.props;

const categoryMap: Record<string, { emoji: string; thumbClass: string }> = {
  '制度・手続き': { emoji: '📋', thumbClass: 'thumb-seido' },
  '働く': { emoji: '💼', thumbClass: 'thumb-hataraku' },
  '暮らす': { emoji: '🏠', thumbClass: 'thumb-kurasu' },
  '体験談': { emoji: '🌙', thumbClass: 'thumb-taiken' },
};
const cat = categoryMap[category] || categoryMap['制度・手続き'];
---
<a href={href} class="article-card">
  <div class={`article-thumb ${cat.thumbClass}`} aria-hidden="true">{cat.emoji}</div>
  <div class="article-body">
    <div class="article-tag">
      {category}
      {isPR && <span class="pr-badge">PR</span>}
    </div>
    <h2>{title}</h2>
    <div class="article-meta">{date}</div>
  </div>
</a>
