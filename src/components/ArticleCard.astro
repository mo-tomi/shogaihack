---
interface Props {
  title: string;
  href: string;
  category: string;
  date: string;
  isPR?: boolean;
  image?: string;
}
const { title, href, category, date, isPR = false, image } = Astro.props;

const categoryMap: Record<string, { emoji: string; thumbClass: string }> = {
  '制度・お金': { emoji: '📋', thumbClass: 'thumb-seido' },
  '働く':      { emoji: '💼', thumbClass: 'thumb-hataraku' },
  '暮らす':    { emoji: '🏠', thumbClass: 'thumb-kurasu' },
};
const cat = categoryMap[category] ?? categoryMap['働く'];
---
<a href={href} class="article-card">
  <div class={`article-thumb ${cat.thumbClass}`} aria-hidden="true">
    {image
      ? <img src={image} alt="" loading="lazy" decoding="async" />
      : cat.emoji
    }
  </div>
  <div class="article-body">
    <div class="article-tag">
      {category}
      {isPR && <span class="pr-badge">PR</span>}
    </div>
    <h2>{title}</h2>
    <div class="article-meta">{date}</div>
  </div>
</a>
