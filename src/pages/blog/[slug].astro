---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection, render } from 'astro:content';
import DiscordCTA from '../../components/DiscordCTA.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Related articles
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const currentTags = new Set(post.data.tags);
const relatedPosts = allPosts
  .filter(p => p.id !== post.id)
  .map(p => ({
    post: p,
    sharedTags: p.data.tags.filter(t => currentTags.has(t)).length,
    sameCategory: p.data.category === post.data.category ? 1 : 0,
  }))
  .sort((a, b) => {
    if (b.sharedTags !== a.sharedTags) return b.sharedTags - a.sharedTags;
    if (b.sameCategory !== a.sameCategory) return b.sameCategory - a.sameCategory;
    return b.post.data.publishedAt.valueOf() - a.post.data.publishedAt.valueOf();
  })
  .slice(0, 4)
  .map(c => c.post);

const publishedDate = post.data.publishedAt.toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric'
});
const updatedDate = post.data.updatedAt?.toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---
<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
  type="article"
>
  <article>
    <!-- Article Header -->
    <div class="article-header">
      <div class="cat-label">{post.data.category}</div>
      <h1>{post.data.title}</h1>
      <div class="meta-row">
        <span>公開：{publishedDate}</span>
        {updatedDate && <span>更新：{updatedDate}</span>}
        <span>著者：{post.data.author}</span>
      </div>
      <div style="display: flex; gap: 8px; flex-wrap: wrap;">
        {post.data.isPR && <span class="pr-notice">PR（広告を含みます）</span>}
        {post.data.supervised
          ? <span class="supervised-badge">✓ 専門家監修済み</span>
          : <span class="unsupervised-badge">専門家確認前</span>
        }
      </div>
      {post.data.tags.length > 0 && (
        <div class="tag-list">
          {post.data.tags.map((tag) => (
            <a href={`/tag/${tag}/`} class="tag-pill">{tag}</a>
          ))}
        </div>
      )}
    </div>

    <!-- Article Body -->
    <div class="prose">
      <Content />

      <!-- Disclaimer -->
      <div class="disclaimer">
        <strong>ご注意：</strong>この記事の情報は {publishedDate} 時点のものです。制度の内容は自治体によって異なる場合があります。最新情報は各自治体の窓口にてご確認ください。
      </div>

      <!-- Author Box -->
      <div class="author-box">
        <img src="/images/author-avatar.webp" alt={post.data.author} width="48" height="48" class="author-icon" />
        <div class="author-info">
          <div class="author-name-row">
            <span class="name">{post.data.author}</span>
            <span class="author-sep">│</span>
            <span class="author-sub">編集長 TOMI</span>
          </div>
          <div class="bio">障がい者グループホームで働きながら、福祉制度・就労支援・暮らしの情報を発信しています。</div>
        </div>
      </div>

      <!-- LINE CTA -->
      <div class="line-cta">
        <p>制度改正の最新情報をLINEでお届け</p>
        <a href="#">友だち追加する</a>
      </div>
    </div>
    <DiscordCTA />

    {relatedPosts.length > 0 && (
      <aside class="related-articles" aria-labelledby="related-heading">
        <div class="section-label" id="related-heading">関連する記事</div>
        <section class="article-list" aria-label="関連記事一覧">
          {relatedPosts.map((rp) => (
            <ArticleCard
              title={rp.data.title}
              href={`/blog/${rp.id}`}
              category={rp.data.category}
              date={rp.data.publishedAt.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
              isPR={rp.data.isPR}
              image={rp.data.image}
            />
          ))}
        </section>
      </aside>
    )}
  </article>
</BaseLayout>
