---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { fetchPageViews } from '../lib/ga4';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const pageViews = await fetchPageViews();
const hasPV = pageViews.size > 0;

const posts = allPosts.sort((a, b) => {
  if (hasPV) {
    const diff = (pageViews.get(a.id) ?? 0) - (pageViews.get(b.id) ?? 0);
    if (diff !== 0) return -diff;
  }
  return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
});
---
<BaseLayout title="障がいHACK">
  <div class="container">
    <!-- Hero -->
    <section class="hero">
      <h1>障がいを持つあなたの毎日に、<br />ちょっとした工夫を。</h1>
      <p>制度のこと、働き方のこと、暮らしのこと。<br />福祉の現場から、あなたに役立つ情報をお届けします。</p>
      <div class="cat-pills">
        <a href="/category/hataraku/" class="cat-pill">働く</a>
        <a href="/category/seido/" class="cat-pill">制度・お金</a>
        <a href="/category/kurasu/" class="cat-pill">暮らす</a>
        <a href="/tags/" class="cat-pill">タグから探す</a>
      </div>
    </section>

    <!-- Article List -->
    <div class="section-label">{hasPV ? 'よく読まれている記事' : 'あたらしい記事'}</div>
    <section class="article-list" aria-label="記事一覧">
      {posts.map((post) => (
        <ArticleCard
          title={post.data.title}
          href={`/blog/${post.id}/`}
          category={post.data.category}
          date={post.data.publishedAt.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
          isPR={post.data.isPR}
          image={post.data.image}
        />
      ))}
    </section>

    <!-- LINE CTA -->
    <div class="line-cta">
      <p>制度改正の情報をLINEでお届けします</p>
      <a href="#">LINE公式アカウントを友だち追加</a>
    </div>
  </div>
</BaseLayout>
