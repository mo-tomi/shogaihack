---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title,
  description = '障がいを持つあなたの毎日に、ちょっとした工夫を。福祉制度・就労支援・暮らしの情報をわかりやすくお届けします。',
  image = '/ogp-default.png',
  type = 'website',
  noindex = false,
} = Astro.props;

const siteTitle = '障がいHACK';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noindex && <meta name="robots" content="noindex" />}

  <!-- OGP -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content={siteTitle} />
  <meta property="og:locale" content="ja_JP" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-1TVBL93BTM"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-1TVBL93BTM');
  </script>

  <!-- Google AdSense 審査用 -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6513356386229286" crossorigin="anonymous"></script>
</head>
<body>
  <!-- WCAG 2.4.1: Skip Link -->
  <a href="#main-content" class="skip-link">本文へジャンプ</a>

  <!-- Header -->
  <header class="site-header" role="banner">
    <div class="inner">
      <a href="/" class="site-logo" aria-label="障がいHACK トップページ">
        <img src="/logo.png" alt="障がいHACK" class="site-logo-img" />
      </a>
      <button
        class="nav-toggle"
        aria-label="メニューを開く"
        aria-expanded="false"
        onclick="this.setAttribute('aria-expanded', this.getAttribute('aria-expanded') === 'true' ? 'false' : 'true'); this.nextElementSibling.classList.toggle('open')"
      >☰</button>
      <nav aria-label="メインナビゲーション">
        <ul class="site-nav">
          <li><a href="/category/seido">制度・手続き</a></li>
          <li><a href="/category/hataraku">働く</a></li>
          <li><a href="/category/kurasu">暮らす</a></li>
          <li><a href="/category/taiken">体験談</a></li>
          <li><a href="/about">運営者情報</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- Main -->
  <main id="main-content" role="main">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="site-footer" role="contentinfo">
    <div class="container">
      <nav class="footer-links" aria-label="フッターナビゲーション">
        <a href="/about">運営者情報</a>
        <a href="/editorial-policy">編集ポリシー</a>
        <a href="/privacy-policy">プライバシーポリシー</a>
        <a href="/accessibility">アクセシビリティ</a>
      </nav>
      <p>&copy; 2026 障がいHACK編集部. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
