---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---
<BaseLayout title="障がいHACK">
  <div class="container">
    <!-- Hero -->
    <section class="hero">
      <h1>障がいを持つあなたの毎日に、<br />ちょっとした工夫を。</h1>
      <p>制度のこと、働き方のこと、暮らしのこと。<br />福祉の現場から、あなたに役立つ情報をお届けします。</p>
      <div class="cat-pills">
        <a href="/category/seido" class="cat-pill">制度・手続き</a>
        <a href="/category/hataraku" class="cat-pill">働く</a>
        <a href="/category/kurasu" class="cat-pill">暮らす</a>
        <a href="/category/taiken" class="cat-pill">体験談</a>
      </div>
    </section>

    <!-- Article List -->
    <div class="section-label">あたらしい記事</div>
    <section class="article-list" aria-label="記事一覧">
      {posts.map((post) => (
        <ArticleCard
          title={post.data.title}
          href={`/blog/${post.id}`}
          category={post.data.category}
          date={post.data.publishedAt.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
          isPR={post.data.isPR}
        />
      ))}
    </section>

    <!-- LINE CTA -->
    <div class="line-cta">
      <p>制度改正の情報をLINEでお届けします</p>
      <a href="#">LINE公式アカウントを友だち追加</a>
    </div>
  </div>
</BaseLayout>
